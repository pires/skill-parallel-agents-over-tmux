#!/usr/bin/env bash
# Pre-commit hook: lint staged markdown files.
set -euo pipefail

# Check if any markdown files are staged
md_files=$(git diff --cached --name-only --diff-filter=ACM -- '*.md') || true
if [[ -z "$md_files" ]]; then
  exit 0
fi

if ! command -v task &>/dev/null; then
  echo "pre-commit: 'task' not found, skipping markdown lint" >&2
  exit 0
fi

echo "pre-commit: linting markdown..."
task lint:md
